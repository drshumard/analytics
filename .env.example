# ============================================================================
# Dr Shumard Analytics — Environment Configuration
# Copy to .env and fill in your values
# ============================================================================

# Server
PORT=3000
NODE_ENV=production

# Supabase PostgreSQL
# Find these in: Supabase Dashboard → Settings → Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Direct PostgreSQL connection (for migrations)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# API Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your-webhook-api-key-here

# CORS — comma-separated origins allowed to hit the API
# Set to your dashboard domain in production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Timezone
TZ=America/Los_Angeles
